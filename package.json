{
  "name": "mapty-ts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "dev": "http-server .",
    "build:app": "tsc && node scripts/assemble-www.mjs",
    "android": "npm run build:app && npx cap copy android && npx cap open android",
    "android:patch": "node scripts/patch-android.mjs"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/leaflet": "^1.9.0",
    "http-server": "^14.1.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "capacitor-health": "^8.1.2",
    "capacitor-live-activities": "^8.0.0"
  }
}
